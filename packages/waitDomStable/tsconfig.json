{
  "extends": "../../tsconfig.json",
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "lib": ["ES2016", "DOM"],
    "declaration": true,
    "module": "nodenext",
    "target": "es2016",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "incremental": true,
    "moduleResolution": "nodenext",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./*"],
      "@content-modules/*": ["./content-modules/*"]
    }
  }
}
